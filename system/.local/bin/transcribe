#!/usr/bin/env bash

# Parse the command line args
_parse_args() {
	while [[ $# -gt 0 ]]; do
		case "$1" in
		-h | --help)
			echo "Usage: $0 [-o <output_file>] [--trim] <input_file>"
			exit 0
			;;
		-t | --trim)
			TRIM_MODE=true
			shift
			;;
		-o | --output)
			OUTPUT_FILE="$2"
			shift 2
			;;
		*)
			if [[ -z "$INPUT_FILE" ]]; then
				INPUT_FILE="$1"
			else
				echo "Unexpected argument: $1"
				exit 1
			fi
			shift
			;;
		esac
	done

	if [[ -z "$INPUT_FILE" ]]; then
		echo "Error: No input file specified"
		exit 1
	fi
}

INPUT_FILE=""
OUTPUT_FILE=""
TRIM_MODE=false
_parse_args "$@"

if [[ -z "$OUTPUT_FILE" ]]; then
	OUTPUT_FILE="${INPUT_FILE%.*}.txt"
fi

TMP_DIR=$(mktemp -d)
trap "rm -rf '$TMP_DIR'" EXIT

# Extract the file extension from the input file
EXTENSION="${INPUT_FILE##*.}"
TRIMMED_FILE="$TMP_DIR/trimmed.$EXTENSION"

echo "Transcribing $INPUT_FILE..."
if [ "$TRIM_MODE" = true ]; then
	ffmpeg -y -t 60 -i "$INPUT_FILE" -acodec copy "$TRIMMED_FILE" -loglevel quiet
else
	cp "$INPUT_FILE" "$TRIMMED_FILE"
fi

WHISPER_TXT="$TMP_DIR/$(basename "${TRIMMED_FILE%.*}").txt"

PYTORCH_JIT=0 PYTHONWARNINGS="ignore" whisper "$TRIMMED_FILE" \
	--model base --language English --output_format txt --output_dir "$TMP_DIR" --verbose False

cp "$WHISPER_TXT" "$OUTPUT_FILE"
echo "Saved to $OUTPUT_FILE"

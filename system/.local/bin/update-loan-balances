#!/usr/bin/env python3
"""Update Lunch Money loan balances from amortization schedules or Google Sheets.

Configure ~/.config/loan-balances/config.json (see config.example.json), set
LUNCH_MONEY_TOKEN, then run monthly:

    update-loan-balances
    update-loan-balances --dry-run
    update-loan-balances --show-schedule
    update-loan-balances --loan Mortgage
"""

from __future__ import annotations

import argparse
import json
import os
import re
import sys
import urllib.error
import urllib.parse
import urllib.request
from datetime import date, datetime
from decimal import Decimal, ROUND_HALF_UP
from pathlib import Path

API_BASE = "https://dev.lunchmoney.app/v1/assets"
CONFIG_PATH = Path(
    os.environ.get("LOAN_BALANCES_CONFIG", "~/.config/loan-balances/config.json")
).expanduser()
MONEY_PLACES = Decimal("0.01")


def parse_date(value: str) -> date:
    return datetime.strptime(value, "%Y-%m-%d").date()


def months_between(start: date, end: date) -> int:
    return (end.year - start.year) * 12 + (end.month - start.month)


def load_config(path: Path) -> dict:
    if not path.exists():
        print(
            f"Error: config not found at {path}\n"
            "Copy ~/.config/loan-balances/config.example.json to config.json and edit it.",
            file=sys.stderr,
        )
        sys.exit(1)

    with path.open() as config_file:
        config = json.load(config_file)

    loans = config.get("loans")
    if not loans:
        print("Error: config must include a non-empty loans array", file=sys.stderr)
        sys.exit(1)

    return config


def validate_loan(loan: dict) -> None:
    required = ["name", "asset_id", "source"]
    missing = [key for key in required if key not in loan]
    if missing:
        raise ValueError(
            f"loan {loan.get('name', '?')}: missing keys: {', '.join(missing)}"
        )

    source = loan["source"]
    if source == "amortization":
        amortization_keys = [
            "loan_start",
            "loan_end",
            "annual_interest_rate",
            "balance_as_of",
            "balance",
        ]
        missing = [key for key in amortization_keys if key not in loan]
        if missing:
            raise ValueError(
                f"loan {loan['name']}: amortization source missing keys: {', '.join(missing)}"
            )
    elif source == "sheet":
        sheet_keys = ["spreadsheet_id", "cell"]
        missing = [key for key in sheet_keys if key not in loan]
        if missing:
            raise ValueError(
                f"loan {loan['name']}: sheet source missing keys: {', '.join(missing)}"
            )
    else:
        raise ValueError(
            f"loan {loan['name']}: unknown source {source!r} (expected amortization or sheet)"
        )


def quantize_money(value: Decimal) -> Decimal:
    return value.quantize(MONEY_PLACES, rounding=ROUND_HALF_UP)


def monthly_rate(annual_interest_rate: Decimal) -> Decimal:
    return annual_interest_rate / Decimal("100") / Decimal("12")


def balance_after_payments(
    principal: Decimal, rate: Decimal, term_months: int, payments_made: int
) -> Decimal:
    if term_months <= 0:
        return Decimal("0")
    if payments_made <= 0:
        return principal
    if payments_made >= term_months:
        return Decimal("0")

    growth = (Decimal("1") + rate) ** term_months
    paid = (Decimal("1") + rate) ** payments_made
    return principal * (growth - paid) / (growth - Decimal("1"))


def derive_initial_principal(
    known_balance: Decimal,
    rate: Decimal,
    term_months: int,
    payments_made: int,
) -> Decimal:
    if payments_made <= 0:
        return known_balance
    if payments_made >= term_months:
        return Decimal("0")

    growth = (Decimal("1") + rate) ** term_months
    paid = (Decimal("1") + rate) ** payments_made
    denominator = growth - paid
    if denominator == 0:
        raise ValueError("Cannot derive principal from the provided loan parameters")

    return known_balance * (growth - Decimal("1")) / denominator


def monthly_payment(principal: Decimal, rate: Decimal, term_months: int) -> Decimal:
    if term_months <= 0:
        return Decimal("0")
    if rate == 0:
        return principal / Decimal(term_months)

    growth = (Decimal("1") + rate) ** term_months
    return principal * rate * growth / (growth - Decimal("1"))


def build_schedule(loan: dict) -> tuple[list[dict], Decimal, Decimal]:
    loan_start = parse_date(loan["loan_start"])
    loan_end = parse_date(loan["loan_end"])
    balance_as_of = parse_date(loan["balance_as_of"])
    known_balance = Decimal(str(loan["balance"]))
    annual_rate = Decimal(str(loan["annual_interest_rate"]))

    term_months = months_between(loan_start, loan_end)
    if term_months <= 0:
        raise ValueError(f"loan {loan['name']}: loan_end must be after loan_start")

    anchor_month = months_between(loan_start, balance_as_of)
    if anchor_month < 0 or anchor_month > term_months:
        raise ValueError(
            f"loan {loan['name']}: balance_as_of must fall between loan_start and loan_end"
        )

    rate = monthly_rate(annual_rate)
    principal = derive_initial_principal(known_balance, rate, term_months, anchor_month)
    payment = monthly_payment(principal, rate, term_months)

    schedule: list[dict] = []
    for month_index in range(term_months + 1):
        month_date = date(
            loan_start.year + (loan_start.month - 1 + month_index) // 12,
            (loan_start.month - 1 + month_index) % 12 + 1,
            loan_start.day,
        )
        remaining = balance_after_payments(principal, rate, term_months, month_index)
        schedule.append(
            {
                "month_index": month_index,
                "date": month_date,
                "balance": quantize_money(remaining),
            }
        )

    return schedule, quantize_money(payment), quantize_money(principal)


def balance_for_today(
    schedule: list[dict], loan_start: date, today: date
) -> Decimal | None:
    month_index = months_between(loan_start, today)
    if month_index < 0:
        return None
    if month_index >= len(schedule):
        return Decimal("0")
    return schedule[month_index]["balance"]


def format_money(value: Decimal) -> str:
    return f"${value:,.2f}"


def print_schedule(
    loan_name: str,
    schedule: list[dict],
    payment: Decimal,
    principal: Decimal,
    today: date,
    loan_start: date,
) -> None:
    current_month = months_between(loan_start, today)
    print(f"Loan: {loan_name}")
    print(f"Initial principal: {format_money(principal)}")
    print(f"Monthly payment:   {format_money(payment)}")
    print()
    print("Month  Date        Balance")
    print("-----  ----------  -------------")
    for entry in schedule:
        marker = " <-- current" if entry["month_index"] == current_month else ""
        print(
            f"{entry['month_index']:>5}  {entry['date'].isoformat()}  "
            f"{format_money(entry['balance'])}{marker}"
        )
    print()


def sheet_export_url(spreadsheet_id: str, cell: str, gid: str | None = None) -> str:
    params = {
        "tqx": "out:csv",
        "range": cell,
    }
    if gid:
        params["gid"] = gid
    query = urllib.parse.urlencode(params)
    return f"https://docs.google.com/spreadsheets/d/{spreadsheet_id}/gviz/tq?{query}"


def fetch_sheet_cell(spreadsheet_id: str, cell: str, gid: str | None = None) -> str:
    request = urllib.request.Request(
        sheet_export_url(spreadsheet_id, cell, gid),
        headers={"User-Agent": "update-loan-balances/1.0"},
    )

    try:
        with urllib.request.urlopen(request) as response:
            raw = response.read().decode().strip()
    except urllib.error.HTTPError as error:
        body = error.read().decode()
        print(f"Error: Google Sheets returned {error.code}: {body}", file=sys.stderr)
        sys.exit(1)
    except urllib.error.URLError as error:
        print(f"Error: failed to fetch sheet: {error.reason}", file=sys.stderr)
        sys.exit(1)

    if not raw:
        print(f"Error: cell {cell} is empty", file=sys.stderr)
        sys.exit(1)

    return raw.strip('"').strip()


def parse_sheet_balance(value: str) -> Decimal:
    cleaned = value.strip().strip('"').strip()
    cleaned = cleaned.replace("$", "").replace(",", "")
    if not re.fullmatch(r"-?\d+(\.\d+)?", cleaned):
        print(f"Error: could not parse balance from {value!r}", file=sys.stderr)
        sys.exit(1)
    return Decimal(cleaned)


def resolve_balance(
    loan: dict, today: date, show_schedule: bool
) -> tuple[Decimal, str | None]:
    if loan["source"] == "amortization":
        loan_start = parse_date(loan["loan_start"])
        schedule, payment, principal = build_schedule(loan)
        balance = balance_for_today(schedule, loan_start, today)
        if balance is None:
            raise ValueError(
                f"loan {loan['name']}: {today.isoformat()} is before loan_start"
            )

        if show_schedule:
            print_schedule(
                loan["name"], schedule, payment, principal, today, loan_start
            )

        month_index = months_between(loan_start, today)
        detail = f"payment month {month_index} ({today.strftime('%B %Y')})"
        return balance, detail

    raw_value = fetch_sheet_cell(
        loan["spreadsheet_id"],
        loan["cell"],
        loan.get("gid"),
    )
    balance = parse_sheet_balance(raw_value)
    detail = f"sheet cell {loan['cell']}: {raw_value}"
    return balance, detail


def update_lunch_money(
    asset_id: str, balance: Decimal, balance_as_of: str, token: str
) -> dict:
    payload = json.dumps(
        {
            "balance": str(balance),
            "balance_as_of": balance_as_of,
        }
    ).encode()
    request = urllib.request.Request(
        f"{API_BASE}/{asset_id}",
        data=payload,
        headers={
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json",
        },
        method="PUT",
    )

    try:
        with urllib.request.urlopen(request) as response:
            return json.loads(response.read().decode())
    except urllib.error.HTTPError as error:
        body = error.read().decode()
        print(f"Error: Lunch Money API returned {error.code}: {body}", file=sys.stderr)
        sys.exit(1)


def select_loans(config: dict, loan_name: str | None) -> list[dict]:
    loans = config["loans"]
    if loan_name:
        matches = [loan for loan in loans if loan.get("name") == loan_name]
        if not matches:
            names = ", ".join(loan.get("name", "?") for loan in loans)
            print(
                f"Error: loan {loan_name!r} not found (available: {names})",
                file=sys.stderr,
            )
            sys.exit(1)
        return matches
    return loans


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Update Lunch Money loan balances from amortization schedules or Google Sheets."
    )
    parser.add_argument(
        "--config",
        type=Path,
        default=CONFIG_PATH,
        help=f"Path to config JSON (default: {CONFIG_PATH})",
    )
    parser.add_argument(
        "--loan",
        help="Update only the loan with this name",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Calculate balances without calling Lunch Money",
    )
    parser.add_argument(
        "--show-schedule",
        action="store_true",
        help="Print amortization schedules for amortization loans",
    )
    parser.add_argument(
        "--date",
        dest="as_of",
        help="Override balance_as_of (YYYY-MM-DD); defaults to today",
    )
    args = parser.parse_args()

    config = load_config(args.config)
    loans = select_loans(config, args.loan)
    today = parse_date(args.as_of) if args.as_of else date.today()
    balance_as_of = today.isoformat()

    for loan in loans:
        try:
            validate_loan(loan)
        except ValueError as error:
            print(f"Error: {error}", file=sys.stderr)
            sys.exit(1)

    token = None if args.dry_run else os.environ.get("LUNCH_MONEY_TOKEN")
    if not args.dry_run and not token:
        print(
            "Error: LUNCH_MONEY_TOKEN environment variable is required", file=sys.stderr
        )
        sys.exit(1)

    for loan in loans:
        balance, detail = resolve_balance(loan, today, args.show_schedule)
        print(f"Loan: {loan['name']}")
        print(detail)
        print(f"Balance as of {balance_as_of}: {format_money(balance)}")

        if args.dry_run:
            print("Dry run: skipping Lunch Money update")
        else:
            print(f"Updating Lunch Money asset {loan['asset_id']}...")
            update_lunch_money(loan["asset_id"], balance, balance_as_of, token)
            print("Updated!")

        print()


if __name__ == "__main__":
    main()

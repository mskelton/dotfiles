# vim:ft=bash

# Git merge
alias gmc="git mc"
alias gmd="git md"
alias gmm="git md"
alias gml="git ml"

# Git rebase
alias grc="git rc"
alias grd="git rd"
alias grl="git rl"

# Git
alias pub="git pub"
alias pull="git pull"
alias push="git push"
alias psh="git push"
alias st="git status"
alias gs="git status"
alias stash="git stash push -u"
alias unstash="git unstash"
alias cpr="$HOME/go/bin/pr"
alias cprd="$HOME/go/bin/pr -d"
alias main="git-cleanup"

# Package managers
alias b="bun"
alias y="yarn"
alias yd="yarn dev"
alias yt="yarn test:e2e"
alias yr="yarn test:e2e:record"
alias yrl="yarn test:e2e:record --last-failed"
alias pn="pnpm"
alias pout="pnpm outdated --format=list"
alias pup="pnpm up --filter='*' --latest"

# Remap vim to nvim
alias vim="nvim"
alias vi="nvim"
alias vis="VIMRUNTIME=$HOME/dev/neovim/runtime $HOME/dev/neovim/build/bin/nvim --luamod-dev"
alias ovim="/usr/bin/vim"

# Use new bash
alias bash="/usr/bin/env bash"
alias oldbash="/bin/bash"

# Kitty
alias icat="/Applications/kitty.app/Contents/MacOS/kitty +kitten icat --align=left"

# Agents
alias c="claude --dangerously-skip-permissions"
alias cr="claude --dangerously-skip-permissions --resume"
alias cc="claude --dangerously-skip-permissions --continue"
alias cx="codex --dangerously-bypass-approvals-and-sandbox"
alias ag="agent --force"
alias agr="agent --force --resume"
alias agc="agent --force --continue"
alias crc="claude remote-control --permission-mode bypassPermissions"

# Misc
alias pb="pbcopy"
alias python='python3'
alias xit="exit"
